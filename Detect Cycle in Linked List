class ListNode:
    def __init__(self, val):
        self.val = val
        self.next = None

a = ListNode(1)
b = ListNode(2)
c = ListNode(3)

a.next = b
b.next = c
c.next = a  # cycle

slow = fast = a

has_cycle = False
while fast and fast.next:
    slow = slow.next
    fast = fast.next.next
    
    if slow == fast:
        has_cycle = True
        break

print(has_cycle)