arr = [900,940,950,1100,1500,1800]
dep = [910,1200,1120,1130,1900,2000]

arr.sort()
dep.sort()

i = j = 0
platforms = res = 0

while i < len(arr):
    if arr[i] <= dep[j]:
        platforms += 1
        i += 1
    else:
        platforms -= 1
        j += 1
    
    res = max(res, platforms)

print(res)